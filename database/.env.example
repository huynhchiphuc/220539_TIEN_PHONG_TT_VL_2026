# Database Configuration Template - ComicCraft AI
# Copy this file to .env in backend folder

# =====================================================
# DATABASE CONFIGURATION
# =====================================================

# Database Type (sqlite or mysql)
DB_TYPE=mysql

# MySQL Configuration (if DB_TYPE=mysql)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=comiccraft_ai
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_POOL_SIZE=10

# SQLite Configuration (if DB_TYPE=sqlite)  
SQLITE_DB_PATH=./comiccraft.db

# =====================================================
# APPLICATION SETTINGS
# =====================================================

# API Configuration
VERSION_APP=v1
TITLE_APP=ComicCraft AI API
ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend URL
FRONTEND_URL=http://localhost:5173

# API Key for authentication (optional)
API_KEY=your-secure-api-key-here

# =====================================================
# FILE UPLOAD CONFIGURATION
# =====================================================

# Upload directories
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs
DOWNLOAD_DIR=./utils/download

# Upload limits
MAX_FILE_SIZE=52428800  # 50MB per file
MAX_TOTAL_SIZE=524288000  # 500MB per session
MAX_FILES_PER_SESSION=100
ALLOWED_FILE_TYPES=png,jpg,jpeg,gif,bmp,webp

# Session expiration (hours)
SESSION_EXPIRE_HOURS=24

# =====================================================
# COMIC GENERATION DEFAULTS
# =====================================================

# Default settings
DEFAULT_LAYOUT_MODE=advanced
DEFAULT_PANELS_PER_PAGE=5
DEFAULT_RESOLUTION=2K
DEFAULT_ASPECT_RATIO=auto
DEFAULT_DPI=150
DEFAULT_MARGIN=40
DEFAULT_GAP=30

# =====================================================
# AI ANALYSIS CONFIGURATION  
# =====================================================

# Enable AI features
ENABLE_SHOT_TYPE_ANALYSIS=true
ENABLE_SCENE_CLASSIFICATION=true
ENABLE_CHARACTER_DETECTION=true
ENABLE_FACE_RECOGNITION=false

# AI Model paths (if using local models)
SHOT_TYPE_MODEL_PATH=./models/shot_classifier.pth
SCENE_MODEL_PATH=./models/scene_classifier.pth
FACE_MODEL_PATH=./models/face_recognition.pkl

# Cloud AI APIs (optional)
OPENAI_API_KEY=sk-your-openai-key-here
GOOGLE_VISION_API_KEY=your-google-vision-key

# =====================================================
# SECURITY
# =====================================================

# JWT Secret (if implementing auth)
SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Rate limiting
RATE_LIMIT_PER_MINUTE=20
RATE_LIMIT_PER_HOUR=100

# =====================================================
# DEBUG & LOGGING
# =====================================================

DEBUG=True
LOG_LEVEL=INFO
LOG_FILE=./logs/comiccraft.log

# =====================================================
# PERFORMANCE
# =====================================================

# Worker threads for AI processing
MAX_WORKERS=4

# Image processing
IMAGE_QUALITY=95
THUMBNAIL_SIZE=300

# Cache settings
ENABLE_CACHE=true
CACHE_DIR=./cache
CACHE_EXPIRE_HOURS=24
